{
  "name": "@apps/frontend",
  "private": true,
  "type": "module",
  "version": "1.1.0",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src",
    "start": "cross-env NODE_ENV=production tsx src",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entryServer.ts --outDir dist/server",
    "build": "npm run build:client && npm run build:server",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "typecheck": "vue-tsc --noEmit",
    "generate:openapi": "openapi-typescript ../openApi/openapi/openapi.yaml --output ./src/types/openapi.ts --enum-values"
  },
