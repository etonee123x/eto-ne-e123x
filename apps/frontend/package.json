    "@vuelidate/core": "^2.0.3",
    "@vuelidate/validators": "^2.0.4",
    "@vueuse/core": "^14.1.0",
    "@vueuse/integrations": "^14.1.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "defu": "^6.1.4",
    "eslint-import-resolver-typescript": "^4.4.4",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "is-mobile": "^5.0.0",
    "negotiator": "^1.0.0",
    "ofetch": "^1.5.1",
    "sortablejs": "^1.15.6",
